---
import BaseHead from "../components/common/BaseHead.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) =>
  b.data.startDate.localeCompare(a.data.startDate),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={"Projects | Rodrigo Dias"}
      description={"Some of my most notable projects."}
    />
    <style>
      section {
        margin: 0;
      }

      .projects-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
      }
    </style>
  </head>
  <body>
    <Header title={"Projects | Rodrigo Dias"} />
    <main>
      <section>
        <div class="projects-grid">
          {
            projects.map((project) => (
                <Card
                  title={project.data.name}
                  logo={project.data.logo}
                  stack={project.data.tags}
                  description={project.data.bullets?.[0] ?? "View project details."}
                  link={
                    project.data.url ??
                    (project.data.repo
                      ? `https://github.com/${project.data.repo}`
                      : `/cv?view=list#project-${project.id}`)
                  }
                />
              ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
