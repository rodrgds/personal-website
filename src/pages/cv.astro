---
import { render } from "astro:content";
import BaseHead from "../components/common/BaseHead.astro";
import Footer from "../components/common/Footer.astro";
import Header from "../components/common/Header.astro";
import { FileText, Plus } from "lucide-astro";
import CVEntryCard from "../components/features/cv/CVEntryCard.astro";
import CVNavigation from "../components/features/cv/CVNavigation.svelte";
import CVProjectCard from "../components/features/cv/CVProjectCard.astro";
import CVRelatedLinks from "../components/features/cv/CVRelatedLinks.astro";
import CVSection from "../components/features/cv/CVSection.astro";
import {
  formatCVDate,
  formatCVRange,
  getCVCollectionsData,
  getCVEntryHref,
  getCVRelatedItems,
} from "../cv/data";
import { cvProfiles } from "../cv/profiles";

const cvData = await getCVCollectionsData();

const profileDownloads = Object.entries(cvProfiles).map(([slug, profile]) => ({
  slug,
  label: profile.label,
}));

const getDownloadLabel = (label: string) =>
  `Download ${label.replace("Rodrigo Dias - ", "")}`;

const getEntryVisual = (logo?: string, image?: string): string | undefined =>
  image ?? logo;

const getRelatedLinks = (currentSlug: string, relatedSlugs?: string[]) =>
  getCVRelatedItems(cvData, currentSlug, relatedSlugs).map((item) => ({
    href: getCVEntryHref(cvData, item.slug),
    title: item.title,
  }));

const renderedCollections = await Promise.all([
  Promise.all(
    cvData.experience.map(async (entry) => ({
      ...entry,
      rendered: await render(entry),
    })),
  ),
  Promise.all(
    cvData.projects.map(async (entry) => ({
      ...entry,
      rendered: await render(entry),
    })),
  ),
  Promise.all(
    cvData.education.map(async (entry) => ({
      ...entry,
      rendered: await render(entry),
    })),
  ),
  Promise.all(
    cvData.honors.map(async (entry) => ({
      ...entry,
      rendered: await render(entry),
    })),
  ),
  Promise.all(
    cvData.certifications.map(async (entry) => ({
      ...entry,
      rendered: await render(entry),
    })),
  ),
]);

const [
  renderedExperience,
  renderedProjects,
  renderedEducation,
  renderedHonors,
  renderedCertifications,
] = renderedCollections;

const personalProjects = renderedProjects.filter(
  (entry) => entry.data.category === "personal",
);
const universityProjects = renderedProjects.filter(
  (entry) => entry.data.category === "university",
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="CV | Rodrigo Dias"
      description="Curriculum Vitae and downloadable PDF profiles."
    />
  </head>
  <body>
    <CVNavigation client:load />
    <Header />
    <main>
      <section class="hero">
        <div class="contact-row">
          <a href="mailto:hey@rgo.pt">hey@rgo.pt</a>
          <span>Vila Nova de Gaia, Porto, Portugal</span>
          <a href="https://github.com/rodrgds" target="_blank" rel="noreferrer"
            >github.com/rodrgds</a
          >
          <a
            href="https://linkedin.com/in/rodrigo-dias-177310209"
            target="_blank"
            rel="noreferrer">LinkedIn</a
          >
        </div>
        <div class="downloads">
          {
            profileDownloads.map((profile) => (
              <a
                href={`/cv/${profile.slug}.pdf`}
                class="download-pill"
                data-tooltip={getDownloadLabel(profile.label)}
                title={getDownloadLabel(profile.label)}
                aria-label={getDownloadLabel(profile.label)}
              >
                <FileText size={17} strokeWidth={1.8} aria-hidden="true" />
                {profile.slug !== "compact" && (
                  <Plus
                    class="download-extra-icon"
                    size={10}
                    strokeWidth={2.2}
                    aria-hidden="true"
                  />
                )}
                <span class="sr-only">{getDownloadLabel(profile.label)}</span>
              </a>
            ))
          }
        </div>
      </section>

      <CVSection id="experience" title="Experience">
        {
          renderedExperience.map((entry) => (
            <CVEntryCard
              id={`experience-${entry.id}`}
              title={entry.data.role}
              timeLabel={formatCVRange(
                entry.data.startDate,
                entry.data.endDate,
              )}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              visualAlt={`${entry.data.company} logo`}
            >
              <Fragment slot="meta">
                <p class="meta">
                  {entry.data.url ? (
                    <a href={entry.data.url} target="_blank" rel="noreferrer">
                      {entry.data.company}
                    </a>
                  ) : (
                    entry.data.company
                  )}
                  <span> · {entry.data.type}</span>
                  <span> · {entry.data.location}</span>
                </p>
              </Fragment>

              {entry.data.bullets && entry.data.bullets.length > 0 && (
                <ul>
                  {entry.data.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}

              <CVRelatedLinks
                items={getRelatedLinks(entry.id, entry.data.related)}
              />

              <entry.rendered.Content />
            </CVEntryCard>
          ))
        }
      </CVSection>

      <CVSection
        id="projects"
        title="Projects"
        collapsible
        defaultOpen
        count={personalProjects.length}
      >
        {
          personalProjects.map((entry) => (
            <CVProjectCard
              id={entry.id}
              name={entry.data.name}
              timeLabel={formatCVRange(
                entry.data.startDate,
                entry.data.endDate,
              )}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              logoSize={entry.data.logoSize}
              cvRole={entry.data.cvRole}
              url={entry.data.url}
              repo={entry.data.repo}
              bullets={entry.data.bullets}
              relatedLinks={getRelatedLinks(entry.id, entry.data.related)}
              demoVideo={entry.data.demoVideo}
            >
              <entry.rendered.Content />
            </CVProjectCard>
          ))
        }
      </CVSection>

      <CVSection
        id="university-projects"
        title="University Projects"
        collapsible
        defaultOpen={false}
        count={universityProjects.length}
      >
        {
          universityProjects.map((entry) => (
            <CVProjectCard
              id={entry.id}
              name={entry.data.name}
              timeLabel={formatCVRange(
                entry.data.startDate,
                entry.data.endDate,
              )}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              logoSize={entry.data.logoSize}
              cvRole={entry.data.cvRole}
              url={entry.data.url}
              repo={entry.data.repo}
              bullets={entry.data.bullets}
              relatedLinks={getRelatedLinks(entry.id, entry.data.related)}
              demoVideo={entry.data.demoVideo}
            >
              <entry.rendered.Content />
            </CVProjectCard>
          ))
        }
      </CVSection>

      <CVSection id="education" title="Education">
        {
          renderedEducation.map((entry) => (
            <CVEntryCard
              id={`education-${entry.id}`}
              title={entry.data.institution}
              timeLabel={formatCVRange(
                entry.data.startDate,
                entry.data.endDate,
              )}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              visualAlt={`${entry.data.institution} logo`}
            >
              <Fragment slot="meta">
                <p class="meta">
                  {entry.data.degree} in {entry.data.area} ·{" "}
                  {entry.data.location}
                </p>
                {entry.data.grade && (
                  <p class="meta">
                    Grade: {entry.data.grade}
                    {entry.data.gradeNote ? ` - ${entry.data.gradeNote}` : ""}
                  </p>
                )}
              </Fragment>

              {entry.data.activities && entry.data.activities.length > 0 && (
                <>
                  <p class="subheading">Activities</p>
                  <ul>
                    {entry.data.activities.map((activity) => (
                      <li>{activity}</li>
                    ))}
                  </ul>
                </>
              )}

              {entry.data.bullets && entry.data.bullets.length > 0 && (
                <>
                  <p class="subheading">CV Highlights</p>
                  <ul>
                    {entry.data.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                </>
              )}

              <CVRelatedLinks
                items={getRelatedLinks(entry.id, entry.data.related)}
              />

              <entry.rendered.Content />
            </CVEntryCard>
          ))
        }
      </CVSection>

      <CVSection id="honors" title="Honors">
        {
          renderedHonors.map((entry) => (
            <CVEntryCard
              id={`honor-${entry.id}`}
              title={entry.data.title}
              timeLabel={formatCVDate(entry.data.date)}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              visualAlt={`${entry.data.title} logo`}
            >
              <Fragment slot="meta">
                <p class="meta">
                  {entry.data.issuer}
                  {entry.data.association ? ` · ${entry.data.association}` : ""}
                </p>
              </Fragment>

              {entry.data.bullets && entry.data.bullets.length > 0 && (
                <ul>
                  {entry.data.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}

              <CVRelatedLinks
                items={getRelatedLinks(entry.id, entry.data.related)}
              />

              <entry.rendered.Content />
            </CVEntryCard>
          ))
        }
      </CVSection>

      <CVSection id="certifications" title="Certifications/Courses">
        {
          renderedCertifications.map((entry) => (
            <CVEntryCard
              id={`certification-${entry.id}`}
              title={entry.data.name}
              timeLabel={formatCVDate(entry.data.issueDate)}
              visual={getEntryVisual(entry.data.logo, entry.data.image)}
              visualAlt={`${entry.data.name} logo`}
            >
              <Fragment slot="meta">
                <p class="meta">{entry.data.issuer}</p>
              </Fragment>

              {entry.data.credentialUrl && (
                <p class="meta">
                  <a
                    href={entry.data.credentialUrl}
                    target="_blank"
                    rel="noreferrer"
                  >
                    Credential URL
                  </a>
                </p>
              )}

              {entry.data.expiryDate && (
                <p class="meta">
                  Expires: {formatCVDate(entry.data.expiryDate)}
                </p>
              )}

              {entry.data.bullets && entry.data.bullets.length > 0 && (
                <ul>
                  {entry.data.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}

              <CVRelatedLinks
                items={getRelatedLinks(entry.id, entry.data.related)}
              />

              <entry.rendered.Content />
            </CVEntryCard>
          ))
        }
      </CVSection>
    </main>
    <Footer />
    <script is:inline data-astro-rerun>
      (() => {
        if (window.__cvYouTubeEmbedInitialized) return;
        window.__cvYouTubeEmbedInitialized = true;

        const YOUTUBE_IFRAME_ALLOW =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const poster = target.closest(".video-poster");
          if (!(poster instanceof HTMLButtonElement)) return;

          const shell = poster.closest("[data-cv-youtube-embed]");
          if (!(shell instanceof HTMLElement)) return;

          const embedUrl = poster.dataset.embedUrl;
          const title = poster.dataset.videoTitle;
          if (!embedUrl || !title) return;

          event.preventDefault();

          const iframe = document.createElement("iframe");
          iframe.src = embedUrl;
          iframe.title = title;
          iframe.loading = "lazy";
          iframe.allow = YOUTUBE_IFRAME_ALLOW;
          iframe.allowFullscreen = true;
          iframe.referrerPolicy = "strict-origin-when-cross-origin";

          shell.replaceChildren(iframe);
        });

        document.addEventListener(
          "error",
          (event) => {
            const target = event.target;
            if (!(target instanceof HTMLImageElement)) return;
            if (!target.matches(".video-poster img")) return;

            let urls = [];
            try {
              urls = JSON.parse(target.dataset.thumbnailUrls ?? "[]");
            } catch {
              return;
            }

            if (!Array.isArray(urls)) return;

            const currentIndex = Number(target.dataset.thumbnailIndex ?? "0");
            const nextUrl = urls[currentIndex + 1];

            if (typeof nextUrl !== "string") return;

            target.dataset.thumbnailIndex = String(currentIndex + 1);
            target.src = nextUrl;
          },
          true,
        );
      })();
    </script>
  </body>
</html>

<style>
  .hero {
    --cv-accent: var(--link-color);

    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0 1rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1.55rem;
  }

  .contact-row {
    flex: 1;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.8rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .downloads {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .download-pill {
    --cv-accent: var(--link-color);
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border: 1px solid var(--border-color);
    border-radius: 0.28rem;
    padding: 0;
    font-size: 1rem;
    background: var(--bg-secondary);
    color: var(--link-color);
    text-decoration: none;
    transition:
      background-color 0.16s ease,
      border-color 0.16s ease,
      color 0.16s ease;
  }

  .download-pill :global(svg) {
    stroke: currentColor;
  }

  .download-pill :global(.download-extra-icon) {
    position: absolute;
    top: 0.18rem;
    right: 0.18rem;
    width: 0.52rem;
    height: 0.52rem;
  }

  .download-pill[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.45rem);
    z-index: 2;
    width: max-content;
    max-width: 14rem;
    padding: 0.28rem 0.45rem;
    border: 1px solid var(--border-color);
    border-radius: 0.25rem;
    background: var(--surface-color);
    color: var(--text-color);
    box-shadow: 0 0.25rem 0.8rem rgba(0, 0, 0, 0.12);
    font-size: 0.74rem;
    line-height: 1.2;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.2rem);
    transition:
      opacity 0.16s ease,
      transform 0.16s ease;
  }

  .download-pill[data-tooltip]:hover::after,
  .download-pill[data-tooltip]:focus-visible::after {
    opacity: 1;
    transform: translateY(0);
  }

  .download-pill:hover {
    background: var(--surface-hover);
    border-color: var(--link-color);
    color: var(--accent);
  }

  .download-pill::before {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      gap: 0.7rem;
    }

    .downloads {
      justify-content: flex-start;
    }
  }
</style>
