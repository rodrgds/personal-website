---
import BaseHead from "../components/common/BaseHead.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
import { getCollection } from "astro:content";
import { SOCIALS } from "../data/socials";
import Logo from "../components/common/Logo.astro";
import DateOfBirth from "../components/features/home/date-of-birth.svelte";
import GitHubContributions from "../components/GitHubContributions.svelte";

// import projects from "../data/projects.json";

const posts = await getCollection("blog").then((posts) =>
  posts.sort((a, b) => {
    return new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf();
  })
);

// const res = await fetch("http://localhost:4321/api/location");
// const { lat, lng } = await res.json();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <h2>
        Hey! I'm
        <span class="name-wrap">
          <button class="name-toggle" type="button" aria-label="Animate Rodrigo to rgo.pt">
            <span class="rodrigo-morph" aria-hidden="true">
              <span class="glyph r-upper">R</span>
              <span class="glyph r-lower">r</span>
              <span class="glyph o-1">o</span>
              <span class="glyph d">d</span>
              <span class="glyph r-2">r</span>
              <span class="glyph i">i</span>
              <span class="glyph g">g</span>
              <span class="glyph o-2">o</span>
              <span class="pt-suffix" aria-hidden="true">.🇵🇹</span>
            </span>
          </button>
          <span class="dias">Dias</span>
        </span>
        👋
      </h2>

      <p>Self-taught programmer since the age of 14. Currently, I am <b><DateOfBirth client:load /></b><span style="margin-left: 0.4rem" />years old and a Computer Engineering student at the Faculty of Engineering of the University of Porto.</p>
      <p>
        I love <b><i>teaching</i></b> and <b>learning</b>. I have a special interest in <Logo src="firefox" /> <b>web dev</b>, <Logo src="linux" /> <b>Linux</b>, <b>FOSS</b>, <b>self-hosting</b>, and <i>minimalism</i>.
      </p>
      <p>
        Outside tech, I enjoy 🚴‍♂️ <b>biking</b>, 📷 <b>photography</b>, 🏋️‍♂️ <b>weight lifting</b>, and playing 🏓 <b>table tennis</b>.
      </p>

      See <a href="/now">what I'm up to</a>, check <a href="/uses">what I use</a>, browse <a href="/faves">my favorite media</a>, <a href="mailto:hey@rgo.pt">email me</a> or <a href="/donate">support me</a>.

      <ul class="socials">
        {SOCIALS.map((social) => (
          <li>
            <a href={social.url} target="_blank">
              <Logo src={social.icon_name} size={36} />
            </a>
          </li>
        ))}
      </ul>

      <!-- <h3>Projects</h3>
      <ul>
        {projects.map((project) => (
          <li>
            <time datetime={project.date}>
              {new Date(project.date).toLocaleDateString("en-us", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
            <div class="popover__wrapper">
              <a href={project.link} target="_blank">{project.title}</a>
              <div class="popover__content">
                <h2>{project.title}</h2>
                <time datetime={project.date}>
                  {new Date(project.date).toLocaleDateString("en-us", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                <p>{project.description}</p>
                {project.stack && (
                  <ul class="stack">
                    {project.stack.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                )}
                {project.img && (
                  <img src={project.img} alt={project.title} />
                )}
              </div>
            </div>
          </li>
        ))}
      </ul> -->

      <GitHubContributions client:load />

      <h3>Writings</h3>
      <ul class="writings">
        {
          posts.map((post) => (
            <li>
              <time datetime={post.data.pubDate} transition:name={`blogpost-pubdate-${post.slug}`}>
                {new Date(post.data.pubDate).toLocaleDateString("en-us", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              <a href={"/posts/" + post.slug} transition:name={`blogpost-name-${post.slug}`}>{post.data.title}</a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />

    <script>
      function showCopiedToast() {
        window.dispatchEvent(new CustomEvent('app:toast', {
          detail: {
            message: 'Copied rgo.pt',
            duration: 1700,
          },
        }));
      }

      function showCopyFailedToast() {
        window.dispatchEvent(new CustomEvent('app:toast', {
          detail: {
            message: 'Copy failed',
            duration: 1700,
          },
        }));
      }

      async function copyDomainToClipboard() {
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText('rgo.pt');
            showCopiedToast();
            return;
          }

          const helper = document.createElement('textarea');
          helper.value = 'rgo.pt';
          helper.setAttribute('readonly', '');
          helper.style.position = 'absolute';
          helper.style.left = '-9999px';
          document.body.appendChild(helper);
          helper.select();
          const didCopy = document.execCommand('copy');
          document.body.removeChild(helper);

          if (didCopy) {
            showCopiedToast();
          } else {
            showCopyFailedToast();
          }
        } catch {
          showCopyFailedToast();
        }
      }

      // Use event delegation so the handler works even after client-side navigation
      document.addEventListener('click', function (event) {
        const target = event.target;
        if (!target || !(target instanceof Element)) return;

        const nameButton = target.closest('.name-toggle');
        if (nameButton) {
          copyDomainToClipboard();
          return;
        }

        const expandButton = target.closest('#expand-socials');
        if (!expandButton) return;

        // Extra socials feature removed
      });
    </script>
  </body>
</html>

<style>
  .socials {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0;
    list-style-type: none;
    padding: unset;
    margin: 1rem 0 0 0;
  }

  .socials li {
    list-style-type: none;
  }

  .socials li a {
    display: inline-block;
  }

  .socials li > a:hover::before {
    width: 0;
  }
  
  .socials li > a:hover {
    transform: scale(1.15);
    transition: transform 0.1s;
  }

  .writings {
    list-style-type: none;
    padding: unset;
    margin: 0;
  }
  .writings li {
    display: flex;
  }

  .name-wrap {
    display: inline-flex;
    align-items: baseline;
    gap: 0.24rem;
  }

  .name-toggle {
    position: relative;
    display: inline-block;
    margin: 0;
    padding: 0;
    border: 0;
    background: none;
    color: inherit;
    font: inherit;
    line-height: 1;
    cursor: pointer;
    vertical-align: baseline;
  }

  .name-toggle:not(:hover):not(:focus-visible) .rodrigo-morph {
    animation: rodrigo-hint-glow 2.8s ease-in-out infinite;
  }

  .rodrigo-morph {
    position: relative;
    width: auto;
    height: auto;
    line-height: 1;
    font-family: var(--font-family-mono);
    vertical-align: baseline;
    display: inline-block;
    overflow: visible;
  }

  .rodrigo-morph::before {
    content: "Rodrigo";
    visibility: hidden;
    display: inline-block;
    line-height: 1;
  }

  .glyph {
    position: absolute;
    top: 0;
    left: calc(var(--x) * 1ch);
    display: block;
    line-height: 1em;
    font-family: inherit;
    letter-spacing: 0;
    transition:
      opacity 0.2s ease,
      transform 0.42s cubic-bezier(0.2, 0.75, 0.2, 1);
    will-change: transform, opacity;
  }

  .r-upper {
    --x: 0;
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .r-lower {
    --x: 0;
    opacity: 0;
    transform: translate3d(0, 0.1em, 0) scale(0.88);
  }

  .o-1 {
    --x: 1;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .d {
    --x: 2;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .r-2 {
    --x: 3;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .i {
    --x: 4;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .g {
    --x: 5;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .o-2 {
    --x: 6;
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .dias {
    display: inline-block;
    line-height: 1;
    vertical-align: baseline;
  }

  .pt-suffix {
    position: absolute;
    left: 3.02ch;
    top: 0;
    line-height: 1;
    opacity: 0;
    transform: translate3d(-0.12rem, 0.2rem, 0) scale(0.9);
    transition:
      opacity 0.22s ease,
      transform 0.26s ease;
    transition-delay: 0ms;
  }

  .name-toggle:hover .r-upper,
  .name-toggle:focus-visible .r-upper {
    opacity: 0;
    transform: translate3d(0, -0.08em, 0) scale(1.06);
  }

  .name-toggle:hover .r-lower,
  .name-toggle:focus-visible .r-lower {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .name-toggle:hover .o-1,
  .name-toggle:focus-visible .o-1,
  .name-toggle:hover .d,
  .name-toggle:focus-visible .d,
  .name-toggle:hover .r-2,
  .name-toggle:focus-visible .r-2,
  .name-toggle:hover .i,
  .name-toggle:focus-visible .i {
    opacity: 0;
    transform: translate3d(0, -0.2em, 0) scale(0.9);
  }

  .name-toggle:hover .g,
  .name-toggle:focus-visible .g {
    transform: translate3d(-4ch, 0, 0);
    transition-delay: 40ms;
  }

  .name-toggle:hover .o-2,
  .name-toggle:focus-visible .o-2 {
    transform: translate3d(-4ch, 0, 0);
    transition-delay: 70ms;
  }

  .name-toggle:hover .pt-suffix,
  .name-toggle:focus-visible .pt-suffix {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    transition-delay: 360ms;
  }

  .name-toggle:focus-visible {
    outline: 2px dashed var(--text-color);
    outline-offset: 0.15rem;
    border-radius: 0.2rem;
  }

  .rodrigo-morph::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.14em;
    height: 1px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0;
    pointer-events: none;
  }

  .name-toggle:not(:hover):not(:focus-visible) .rodrigo-morph::after {
    animation: rodrigo-hint-underline 2.8s ease-in-out infinite;
  }

  @keyframes rodrigo-hint-glow {
    0%,
    100% {
      text-shadow: 0 0 0 transparent;
    }
    50% {
      text-shadow: 0 0 0.34rem color-mix(in srgb, currentColor 72%, transparent 28%);
    }
  }

  @keyframes rodrigo-hint-underline {
    0%,
    100% {
      opacity: 0;
      transform: scaleX(0.82);
    }
    50% {
      opacity: 0.36;
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .name-toggle:not(:hover):not(:focus-visible) .rodrigo-morph {
      animation: none;
    }

    .name-toggle:not(:hover):not(:focus-visible) .rodrigo-morph::after {
      animation: none;
    }
  }

  .writings li time {
    flex: 0 0 9.3rem;
    font-family: var(--font-family-mono);
    color: #656565;
  }

  .writings li a:visited {
    color: var(--visited-color);
  }

  .writings li > a:hover::before {
    content: "→";
    width: 0;
    bottom: 1.8rem;
    left: -1.5rem;
  }
  .writings li > a:hover::after {
    content: "←";
    margin-left: 0.5rem;
  }

  .popover__wrapper {
    position: relative;
    margin-top: 0;
    display: inline-block;
  }
  .popover__content {
    opacity: 0;
    visibility: hidden;
    position: absolute;
    top: 4.2rem;
    left: -7rem;
    right: -7rem;
    background-color: var(--background-color);
    border-radius: 0.5rem;
    padding: 1.2rem;
    border: 1px solid #bfbfbf;
    box-shadow: 0 1px 4px 0 var(--text-color);
    width: auto;
  }
  .popover__content:before {
    position: absolute;
    z-index: -1;
    content: "";
    right: calc(50% - 10px);
    top: -1rem;
    border-style: solid;
    border-width: 0 10px 10px 10px;
    border-color: transparent transparent #bfbfbf transparent;
    box-shadow: var(--background-color) 1px 1px 1px;
    transition-duration: 0.3s;
    transition-property: transform;
  }
  .popover__wrapper:hover .popover__content {
    z-index: 10;
    opacity: 1;
    visibility: visible;
    transform: translate(0, -20px);
    transition: all 0.5s cubic-bezier(0.75, -0.02, 0.2, 0.97);
  }
  .stack {
    margin: 0;
    font-family: var(--font-family-mono);
    display: flex;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
    list-style: none;
    gap: 0.5rem;
  }
  .stack li {
    padding: 0.3rem 0.5rem;
    border-radius: 0.5rem;
    border: 2px solid var(--text-color);
    color: var(--text-color);
    opacity: 0.8;
  }
  .popover__content h2 {
    margin: 0;
  }
  .popover__content img {
    margin-top: 1.2rem;
    width: 100%;
    border-radius: 0.5rem;
  }
</style>