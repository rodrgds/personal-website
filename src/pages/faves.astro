---
import BaseHead from "../components/common/BaseHead.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import { SITE_TITLE } from "../config";
import FavoritesPage from "../components/features/favorites/favorites-page.svelte";
import { loadFavorites } from "../lib/favorites/load";

export const prerender = true;

const sections = await loadFavorites();

const title = "Favorites";
const description =
  "My favorite movies, shows, podcasts, books, blogs, articles, videos, and cool stuff.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {title} {description} />
  </head>
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <FavoritesPage client:load {sections} />
    </main>
    <Footer />
  </body>
</html>
