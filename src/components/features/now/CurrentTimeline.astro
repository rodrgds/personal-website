---
import CVEntryAvatar from "../cv/CVEntryAvatar.astro";
import { getCVCollectionsData } from "../../../cv/data";
import {
  TIMELINE_CATEGORY_LABELS,
  getCurrentTimelineEntries,
  getTimelineDateLabel,
  type TimelineEntry,
} from "../../../cv/timeline";

interface Props {
  entries?: TimelineEntry[];
}

const { entries: providedEntries }: Props = Astro.props;
const entries =
  providedEntries ?? getCurrentTimelineEntries(await getCVCollectionsData());
---

<div class="current-timeline">
  <ul>
    {
      entries.map((entry) => (
        <li class={`current-${entry.category}`}>
          <a href={entry.href}>
            <div class="current-card-inner">
              <span class="current-node" aria-hidden="true" />
              <CVEntryAvatar
                title={entry.title}
                visual={entry.visual}
                alt={`${entry.title} logo`}
                size={28}
                visualSize={22}
                accent="var(--current-color)"
              />
              <span class="current-copy">
                <strong>{entry.title}</strong>
                <span>{entry.subtitle}</span>
              </span>
              <span class="current-meta">
                <span>{TIMELINE_CATEGORY_LABELS[entry.category]}</span>
                <time>{getTimelineDateLabel(entry)}</time>
              </span>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
  <p class="current-link"><a href="/cv">Explore the full timeline →</a></p>
</div>

<style>
  .current-timeline {
    margin: 0.45rem 0 1.6rem;
  }

  ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    --current-color: var(--flexoki-orange);
    min-width: 0;
  }

  .current-personal-projects {
    --current-color: var(--flexoki-cyan);
  }

  .current-university-projects {
    --current-color: var(--flexoki-green);
  }

  .current-education {
    --current-color: var(--flexoki-blue);
  }

  a {
    position: relative;
    display: flex;
    min-height: 4rem;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.6rem 0.55rem 0.8rem;
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 0.42rem;
    background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
    color: var(--text-color);
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  a::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    background: var(--current-color);
    content: "";
  }

  .current-card-inner {
    display: contents;
  }

  a:hover,
  a:focus-visible {
    border-color: color-mix(
      in srgb,
      var(--current-color) 55%,
      var(--border-color)
    );
    background: var(--surface-hover);
  }

  .current-node {
    position: absolute;
    top: 0.62rem;
    left: -0.22rem;
    width: 0.48rem;
    height: 0.48rem;
    border: 2px solid var(--current-color);
    border-radius: 50%;
    background: var(--surface-color);
  }

  .current-copy {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    line-height: 1.2;
  }

  .current-copy strong,
  .current-copy span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .current-copy strong {
    color: var(--heading-color);
    font-size: 0.88rem;
  }

  .current-copy span {
    margin-top: 0.18rem;
    color: var(--gray-color);
    font-size: 0.72rem;
  }

  .current-meta {
    display: flex;
    flex: 0 0 auto;
    align-items: end;
    flex-direction: column;
    color: var(--gray-color);
    font-family: var(--font-family-mono);
    font-size: 0.58rem;
    line-height: 1.4;
  }

  .current-meta > span {
    color: var(--current-color);
  }

  .current-link {
    margin: 0.55rem 0 0;
    text-align: right;
    font-size: 0.82rem;
  }

  .current-link a {
    display: inline;
    min-height: 0;
    padding: 0;
    overflow: visible;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--link-color);
    text-decoration: underline;
  }

  .current-link a::before {
    display: none;
  }

  @media (max-width: 700px) {
    ul {
      grid-template-columns: 1fr;
    }

    .current-meta {
      display: none;
    }
  }
</style>
