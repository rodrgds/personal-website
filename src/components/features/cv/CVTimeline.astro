---
import CVEntryAvatar from "./CVEntryAvatar.astro";
import {
  TIMELINE_CATEGORIES,
  TIMELINE_CATEGORY_LABELS,
  buildTimelineLayout,
  getTimelineDateLabel,
  type TimelineEntry,
  type TimelineCategory,
} from "../../../cv/timeline";

interface Props {
  entries: TimelineEntry[];
  variant?: "detailed" | "icons";
}

const { entries, variant = "detailed" }: Props = Astro.props;
const compact = variant === "icons";
const layout = buildTimelineLayout(entries);
const monthWidth = 20;
const contentInset = 34;
const labelSpace = compact ? 34 : 220;
const rowHeight = compact ? 38 : 66;
const timeWidth = layout.monthCount * monthWidth + contentInset * 2;
const timelineWidth = timeWidth + labelSpace;
const graphRowCount = compact
  ? layout.rowCount
  : Math.max(layout.rowCount, layout.labelRowCount);
const graphHeight = graphRowCount * rowHeight + (compact ? 18 : 34);
const nodeCenter = compact ? 17 : 22;
const nowOffset =
  (layout.endMonth - layout.startMonth - 1) * monthWidth + contentInset;

const categoryColors: Record<TimelineCategory, string> = {
  experience: "var(--flexoki-orange)",
  "personal-projects": "var(--flexoki-cyan)",
  "university-projects": "var(--flexoki-green)",
  education: "var(--flexoki-blue)",
  honors: "var(--flexoki-yellow)",
  certifications: "var(--flexoki-purple)",
};

const getStartOffset = (entry: (typeof layout.entries)[number]) =>
  (entry.startMonth - layout.startMonth) * monthWidth + contentInset;

const getMonthOffset = (month: number) =>
  (month - layout.startMonth) * monthWidth + contentInset;

const getLaneCenter = (row: number) => row * rowHeight + nodeCenter;

const getTrackPath = (entry: (typeof layout.entries)[number]) => {
  const points = entry.lanePoints;
  const end = getMonthOffset(entry.endMonth + 1);
  let currentRow = points[0]?.row ?? entry.row;
  let path = `M ${getStartOffset(entry)} ${getLaneCenter(currentRow)}`;
  const laneChanges = points.slice(1);

  for (const [index, point] of laneChanges.entries()) {
    const transition = getMonthOffset(point.month);
    const nextTransition = laneChanges[index + 1]
      ? getMonthOffset(laneChanges[index + 1].month)
      : end;
    const transitionEnd = Math.min(end, nextTransition, transition + 36);
    const transitionWidth = transitionEnd - transition;
    const firstControl = transition + transitionWidth * 0.42;
    const secondControl = transition + transitionWidth * 0.58;
    const currentY = getLaneCenter(currentRow);
    const nextY = getLaneCenter(point.row);

    path += ` L ${transition} ${currentY}`;
    path += ` C ${firstControl} ${currentY}, ${secondControl} ${nextY}, ${transitionEnd} ${nextY}`;
    currentRow = point.row;
  }

  return `${path} L ${end} ${getLaneCenter(currentRow)}`;
};
---

<section
  class:list={["timeline-shell", compact && "timeline-shell-icons"]}
  aria-labelledby="timeline-title"
>
  <div class="timeline-heading">
    <div>
      <h1 id="timeline-title">Things I’ve done</h1>
      <p>
        {
          compact
            ? "Everything together, from the earliest start to what is active now."
            : "Everything together, from the earliest start to what is active now."
        }
      </p>
    </div>
    <p class="scroll-note" aria-hidden="true">Scroll through time →</p>
  </div>

  <div class="category-legend" aria-label="Timeline categories">
    {
      TIMELINE_CATEGORIES.map((category) => (
        <span style={`--category-color:${categoryColors[category]}`}>
          <span class="legend-dot" aria-hidden="true" />
          {TIMELINE_CATEGORY_LABELS[category]}
        </span>
      ))
    }
  </div>

  <div
    class="timeline-scroller"
    data-timeline-scroller
    tabindex="0"
    role="region"
    aria-label="Horizontal life timeline, ordered from oldest at the top to newest at the bottom. Scroll horizontally to explore the years."
  >
    <div
      class="timeline-canvas"
      style={`--timeline-width:${timelineWidth}px;--time-width:${timeWidth}px;--month-width:${monthWidth}px;--content-inset:${contentInset}px;--row-height:${rowHeight}px`}
    >
      <div class="axis" aria-hidden="true">
        <div class="axis-line"></div>
        {
          layout.ticks.map((tick) => {
            const left =
              (tick.month - layout.startMonth) * monthWidth + contentInset;
            return (
              <span
                class:list={["axis-tick", tick.label && "axis-tick-year"]}
                style={`left:${left}px`}
              >
                {tick.label && <span>{tick.label}</span>}
              </span>
            );
          })
        }
        <span class="now-axis" style={`left:${nowOffset}px`}>
          <span>Now</span>
        </span>
      </div>

      <div class="activity" aria-label="Monthly activity density">
        <span class="activity-label">Busy</span>
        <div class="activity-bars" aria-hidden="true">
          {
            layout.density.map((count, index) => (
              <span
                title={`${count} active ${count === 1 ? "thing" : "things"}`}
                style={`height:${Math.max(2, (count / layout.maxDensity) * 28)}px;left:${index * monthWidth + contentInset}px`}
              />
            ))
          }
        </div>
      </div>

      <div class="unified-graph" style={`height:${graphHeight}px`}>
        <span
          class="now-marker"
          style={`left:${nowOffset}px`}
          aria-hidden="true"></span>

        <svg
          class="entry-tracks"
          width={timelineWidth}
          height={graphHeight}
          viewBox={`0 0 ${timelineWidth} ${graphHeight}`}
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          {
            layout.entries
              .filter((entry) => entry.kind === "span")
              .map((entry) => (
                <path
                  d={getTrackPath(entry)}
                  style={`--entry-color:${categoryColors[entry.category]}`}
                />
              ))
          }
        </svg>

        {
          layout.entries.map((entry) => {
            const color = categoryColors[entry.category];
            const start = getStartOffset(entry);
            const top = entry.row * rowHeight;
            const labelOffset = (entry.labelRow - entry.row) * rowHeight;
            const connectorTop = nodeCenter + Math.min(0, labelOffset);
            const label = `${entry.title}, ${TIMELINE_CATEGORY_LABELS[entry.category]}, ${entry.subtitle}, ${getTimelineDateLabel(entry)}`;

            return (
              <div class="graph-row" style={`top:${top}px`}>
                <span class="row-guide" aria-hidden="true" />
                <a
                  class:list={[
                    "timeline-entry",
                    `timeline-entry-${entry.kind}`,
                    entry.isCurrent && "timeline-entry-current",
                  ]}
                  href={entry.href}
                  data-start-date={entry.startDate}
                  style={`left:${start}px;--entry-color:${color};--entry-label-offset:${labelOffset}px;--entry-connector-top:${connectorTop}px;--entry-connector-height:${Math.abs(labelOffset)}px`}
                  aria-label={label}
                  title={compact ? label : undefined}
                >
                  <span class="entry-node" aria-hidden="true">
                    {compact && (
                      <span class="compact-node-avatar">
                        <CVEntryAvatar
                          title={entry.title}
                          visual={entry.visual}
                          alt=""
                          size={22}
                          visualSize={19}
                          accent="var(--text-color)"
                        />
                      </span>
                    )}
                  </span>
                  {!compact && (
                    <>
                      {labelOffset !== 0 && (
                        <span class="entry-card-connector" aria-hidden="true" />
                      )}
                      <div class="entry-card">
                        <CVEntryAvatar
                          title={entry.title}
                          visual={entry.visual}
                          alt={`${entry.title} logo`}
                          size={25}
                          visualSize={21}
                          accent="var(--entry-color)"
                        />
                        <span class="entry-copy">
                          <span class="entry-category">
                            {TIMELINE_CATEGORY_LABELS[entry.category]}
                          </span>
                          <strong>{entry.title}</strong>
                          <span>{entry.subtitle}</span>
                          <time>{getTimelineDateLabel(entry)}</time>
                        </span>
                      </div>
                    </>
                  )}
                </a>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script is:inline data-astro-rerun>
  requestAnimationFrame(() => {
    const scroller = document.querySelector("[data-timeline-scroller]");
    if (!(scroller instanceof HTMLElement)) return;
    if (scroller.dataset.timelinePositioned === "true") return;

    scroller.scrollLeft = 0;
    scroller.dataset.timelinePositioned = "true";
  });
</script>

<style>
  .timeline-shell {
    width: min(var(--wide-width), calc(100vw - (var(--page-padding) * 2)));
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .timeline-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  h1 {
    margin: 0;
    font-size: 1.75rem;
  }

  .timeline-heading p {
    margin: 0.2rem 0 0;
    color: var(--gray-color);
    font-size: 0.9rem;
  }

  .scroll-note {
    flex: 0 0 auto;
    font-family: var(--font-family-mono);
    font-size: 0.72rem !important;
  }

  .category-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.85rem;
    margin: 0.85rem 0 0.9rem;
    color: var(--gray-color);
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
  }

  .category-legend > span {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .legend-dot {
    width: 0.48rem;
    height: 0.48rem;
    border: 2px solid var(--category-color);
    border-radius: 50%;
  }

  .timeline-scroller {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
    scrollbar-color: var(--gray-color) var(--bg-secondary);
    scrollbar-width: thin;
    border: 1px solid var(--border-color);
    border-radius: 0.65rem;
    background:
      linear-gradient(90deg, var(--background-color), transparent 1.4rem) left /
        2.5rem 100% no-repeat local,
      linear-gradient(-90deg, var(--background-color), transparent 1.4rem)
        right / 2.5rem 100% no-repeat local,
      var(--bg-secondary);
    box-shadow: inset 0 1px color-mix(in srgb, white 20%, transparent);
  }

  .timeline-scroller:focus-visible {
    outline: 2px solid var(--link-color);
    outline-offset: 3px;
  }

  .timeline-canvas {
    position: relative;
    width: var(--timeline-width);
    min-width: 100%;
    padding-top: 0.9rem;
  }

  .axis {
    position: relative;
    width: var(--time-width);
    height: 44px;
    margin-bottom: 0.25rem;
    font-family: var(--font-family-mono);
  }

  .axis-line {
    position: absolute;
    top: 25px;
    left: var(--content-inset);
    right: var(--content-inset);
    height: 1px;
    background: var(--border-color);
  }

  .axis-tick {
    position: absolute;
    top: 21px;
    width: 1px;
    height: 9px;
    background: var(--border-color);
  }

  .axis-tick-year {
    top: 17px;
    height: 17px;
    background: var(--gray-color);
  }

  .axis-tick span {
    position: absolute;
    top: -18px;
    left: 0;
    color: var(--gray-color);
    font-size: 0.68rem;
    transform: translateX(-50%);
  }

  .now-axis {
    position: absolute;
    top: 17px;
    width: 1px;
    height: 17px;
    background: var(--link-color);
  }

  .now-axis span {
    position: absolute;
    top: -18px;
    left: 0.35rem;
    color: var(--link-color);
    font-size: 0.68rem;
  }

  .activity {
    position: relative;
    width: var(--time-width);
    height: 38px;
    border-bottom: 1px solid var(--border-color);
  }

  .activity-label {
    position: sticky;
    left: 0.55rem;
    z-index: 2;
    color: var(--gray-color);
    font-family: var(--font-family-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .activity-bars span {
    position: absolute;
    bottom: 0;
    width: calc(var(--month-width) - 2px);
    border-radius: 2px 2px 0 0;
    background: color-mix(in srgb, var(--link-color) 55%, transparent);
  }

  .unified-graph {
    position: relative;
    width: var(--timeline-width);
  }

  .now-marker {
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 0;
    width: 1px;
    border-left: 1px dashed
      color-mix(in srgb, var(--link-color) 45%, transparent);
  }

  .entry-tracks {
    position: absolute;
    inset: 0;
    z-index: 2;
    overflow: visible;
    pointer-events: none;
  }

  .entry-tracks path {
    fill: none;
    stroke: var(--entry-color);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 4;
    vector-effect: non-scaling-stroke;
  }

  .graph-row {
    position: absolute;
    left: 0;
    z-index: 3;
    width: var(--timeline-width);
    height: var(--row-height);
  }

  .row-guide {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: color-mix(in srgb, var(--border-color) 45%, transparent);
  }

  .timeline-entry {
    position: absolute;
    top: 0;
    z-index: 2;
    display: block;
    width: 12rem;
    height: 64px;
    color: var(--text-color);
    text-decoration: none;
  }

  .entry-node {
    position: absolute;
    top: 15px;
    left: -5px;
    z-index: 3;
    width: 14px;
    height: 14px;
    border: 3px solid var(--entry-color);
    border-radius: 50%;
    background: var(--bg-secondary);
    box-shadow: 0 0 0 3px var(--bg-secondary);
  }

  .timeline-entry-current .entry-node {
    background: var(--entry-color);
    box-shadow:
      0 0 0 3px var(--bg-secondary),
      0 0 0 7px color-mix(in srgb, var(--entry-color) 16%, transparent);
  }

  .entry-card {
    position: absolute;
    top: calc(27px + var(--entry-label-offset));
    left: 10px;
    display: flex;
    width: 11.5rem;
    align-items: center;
    gap: 0.45rem;
    padding: 0.22rem 0.35rem;
    border: 1px solid transparent;
    border-radius: 0.35rem;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      transform 0.15s ease;
  }

  .entry-card-connector {
    position: absolute;
    top: var(--entry-connector-top);
    left: 1px;
    width: 1px;
    height: var(--entry-connector-height);
    border-left: 1px dashed
      color-mix(in srgb, var(--entry-color) 55%, transparent);
    pointer-events: none;
  }

  .timeline-entry:hover .entry-card,
  .timeline-entry:focus-visible .entry-card {
    border-color: color-mix(
      in srgb,
      var(--entry-color) 48%,
      var(--border-color)
    );
    background: var(--surface-color);
    transform: translateY(-1px);
  }

  .timeline-entry:focus-visible {
    outline: none;
  }

  .entry-copy {
    display: grid;
    min-width: 0;
    flex: 1;
    grid-template-columns: 1fr auto;
    line-height: 1.08;
  }

  .entry-category {
    grid-column: 1;
    color: var(--entry-color) !important;
    font-family: var(--font-family-mono);
    font-size: 0.52rem !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .entry-copy strong,
  .entry-copy > span:not(.entry-category) {
    grid-column: 1 / -1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .entry-copy strong {
    color: var(--heading-color);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .entry-copy > span:not(.entry-category) {
    margin-top: 0.1rem;
    color: var(--gray-color);
    font-size: 0.62rem;
  }

  .entry-copy time {
    grid-column: 2;
    grid-row: 1;
    margin-left: 0.35rem;
    color: var(--gray-color);
    font-family: var(--font-family-mono);
    font-size: 0.5rem;
  }

  .timeline-shell-icons .timeline-entry {
    width: 30px;
    height: var(--row-height);
  }

  .timeline-shell-icons .entry-node {
    top: 3px;
    left: -13px;
    display: grid;
    width: 28px;
    height: 28px;
    place-items: center;
    overflow: hidden;
    border-width: 1.5px;
    background: var(--bg-secondary);
    box-shadow: 0 0 0 3px var(--bg-secondary);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.15s ease;
  }

  .timeline-shell-icons .timeline-entry-current .entry-node {
    background: var(--bg-secondary);
    box-shadow:
      0 0 0 3px var(--bg-secondary),
      0 0 0 6px color-mix(in srgb, var(--entry-color) 12%, transparent);
  }

  .timeline-shell-icons .timeline-entry:hover .entry-node,
  .timeline-shell-icons .timeline-entry:focus-visible .entry-node {
    box-shadow:
      0 0 0 3px var(--bg-secondary),
      0 0 0 6px color-mix(in srgb, var(--entry-color) 24%, transparent);
    transform: scale(1.08);
  }

  .timeline-shell-icons .entry-tracks path {
    stroke-width: 3;
  }

  .compact-node-avatar {
    display: grid;
    place-items: center;
  }

  .compact-node-avatar :global(.entry-avatar) {
    border: 0;
    border-radius: 50%;
    background: transparent;
  }

  @media (max-width: 640px) {
    .timeline-shell {
      width: calc(100vw - 1rem);
    }

    .timeline-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
      padding-inline: 1.25rem;
    }

    h1 {
      font-size: 1.45rem;
    }

    .timeline-heading p {
      font-size: 0.82rem;
    }

    .scroll-note {
      display: block;
      align-self: flex-end;
    }

    .category-legend {
      padding-inline: 1.25rem;
    }

    .timeline-scroller {
      border-radius: 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-card {
      transition: none;
    }
  }
</style>
