---
import CVExpandable from "./CVExpandable.svelte";
import CVEntryAvatar from "./CVEntryAvatar.astro";

interface Props {
  id: string;
  title: string;
  timeLabel: string;
  visual?: string;
  visualAlt: string;
  visualSize?: number;
}

const { id, title, timeLabel, visual, visualAlt, visualSize } = Astro.props;
---

<CVExpandable client:load id={id}>
  <Fragment slot="summary">
    <div class="entry-head">
      <div>
        <p class="entry-logo">
          <CVEntryAvatar
            title={title}
            visual={visual}
            alt={visualAlt}
            size={30}
            visualSize={visualSize}
          />
        </p>
        <h3>{title}</h3>
        <slot name="meta" />
      </div>
      <time>{timeLabel}</time>
    </div>
  </Fragment>

  <Fragment slot="details">
    <div class="details-content">
      <slot />
    </div>
  </Fragment>
</CVExpandable>

<style>
  .entry-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  h3 {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.3;
  }

  .entry-logo {
    margin: 0 0 0.35rem 0;
    line-height: 1;
  }

  .details-content :global(p) {
    margin: 0.3rem 0 0.8rem 0;
  }

  .details-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .details-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .details-content :global(ul) {
    margin: 0 0 1rem 1.85rem;
    padding-inline-start: 0.35rem;
    list-style: disc;
  }

  .details-content :global(ol) {
    margin: 0 0 1rem 1.85rem;
    padding-inline-start: 0.35rem;
    list-style: decimal;
  }

  .details-content :global(strong) {
    color: var(--heading-color);
  }

  :global(.meta) {
    margin: 0.12rem 0 0 0;
    font-size: 0.9rem;
    color: var(--gray-color);
  }

  :global(.subheading) {
    margin: 0.8rem 0 0.25rem 0;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-color);
    font-weight: 600;
  }

  time {
    white-space: nowrap;
    font-size: 0.78rem;
    color: var(--gray-color);
    font-family: var(--font-family-mono);
  }

  @media (max-width: 700px) {
    .entry-head {
      flex-direction: column;
      gap: 0.35rem;
    }

    time {
      white-space: normal;
    }
  }
</style>
