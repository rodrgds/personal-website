---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  sizes?: string;
  loading?: "lazy" | "eager";
  class?: string;
}

const {
  src,
  alt,
  sizes = "(max-width: 700px) 100vw, 680px",
  loading = "lazy",
  class: className,
}: Props = Astro.props;

const responsiveWidths = Array.from(
  new Set(
    [400, 800, 1200, 1600, 2000, src.width].filter(
      (width) => width <= src.width,
    ),
  ),
).sort((left, right) => left - right);
---

<Image
  src={src}
  alt={alt}
  sizes={sizes}
  widths={responsiveWidths}
  loading={loading}
  class={className}
/>
