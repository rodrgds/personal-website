---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section class="section">
  <h2 id={id}>{title}</h2>
  <div class="list">
    <slot />
  </div>
</section>

<style>
  .section {
    margin-bottom: 1.8rem;
  }

  .section h2 {
    margin-bottom: 0.9rem;
    font-size: 1.35rem;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
  }
</style>
