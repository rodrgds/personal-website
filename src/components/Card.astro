---
import Logo from "./common/Logo.astro";

export interface Props {
  title: string;
  logo?: string;
  stack: string[];
  description: string;
  link?: string;
}

const { title, logo, stack, description, link } = Astro.props as Props;
const Tag = link ? "a" : "article";
---

<Tag href={link} class:list={["project", !link && "project-static"]}>
  <div class="card-container">
    <div class:list={["img-container", !logo && "text-preview"]}>
      {logo && <Logo src={logo} alt={`${title} logo`} size={64} />}
      <p>{description}</p>
    </div>
    <h2>{title}</h2>
    <ul class="stack">
      {stack.map((item: string) => <li>{item}</li>)}
    </ul>
  </div>
</Tag>
<style>
  .project {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project:hover {
    text-decoration: none;
  }

  .project-static {
    cursor: default;
  }

  p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.45;
    margin: 0;
    padding: 0 1rem 0.9rem;
  }

  .img-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }

  .text-preview {
    display: flex;
    align-items: center;
    min-height: 8.5rem;
    aspect-ratio: auto;
    background: color-mix(in srgb, var(--bg-secondary) 72%, transparent);
  }

  .text-preview p {
    padding: 1rem;
  }

  .card-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    border-radius: 0.35rem;
    border: 1px solid var(--border-color);
    background: var(--surface-color);
    overflow: hidden;
    transition:
      border-color 0.16s ease,
      background-color 0.16s ease;
  }

  .card-container:hover {
    border-color: var(--link-color);
    background: var(--bg-secondary);
  }

  @media (min-width: 768px) {
    .card-container {
      width: 100%;
      height: 100%;
    }
  }

  .img-container :global(img) {
    max-width: 45%;
    max-height: 45%;
  }

  h2 {
    font-size: 1.05rem;
    padding: 0.9rem 1rem 0.35rem;
    margin: 0;
  }

  .stack {
    font-family: var(--font-family-mono);
    display: flex;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
    list-style: none;
    gap: 0.35rem;
    padding: 0 1rem 1rem 1rem;
  }

  ul li {
    padding: 0.18rem 0.42rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border-color);
    color: var(--gray-color);
    font-size: 0.72rem;
  }

  @media (max-width: 620px) {
    .stack {
      justify-content: flex-start;
    }
  }
</style>
