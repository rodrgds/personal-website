---
import "../../styles/global.css";

export interface Props {
  title: string;
  description: string;
  image?: string;
}

import { ClientRouter } from "astro:transitions";

const { title, description, image = "" } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<script is:inline>
  (() => {
    const STORAGE_KEY = "rgo-theme";
    const root = document.documentElement;
    const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

    function getStoredTheme() {
      try {
        const value = window.localStorage.getItem(STORAGE_KEY);
        return value === "dark" || value === "light" ? value : null;
      } catch {
        return null;
      }
    }

    function getSystemTheme() {
      return mediaQuery.matches ? "dark" : "light";
    }

    function updateThemeButtons(theme) {
      const nextTheme = theme === "dark" ? "light" : "dark";

      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
        button.setAttribute("title", `Switch to ${nextTheme} mode`);
      });

      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.dataset.themeState = theme;
      });
    }

    function applyTheme(theme) {
      root.dataset.theme = theme;
      root.style.colorScheme = theme;
      updateThemeButtons(theme);
    }

    applyTheme(getStoredTheme() ?? getSystemTheme());

    if (window.__rgoThemeToggleInitialized) return;
    window.__rgoThemeToggleInitialized = true;

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest("[data-theme-toggle]");
      if (!(button instanceof HTMLButtonElement)) return;

      const currentTheme =
        root.dataset.theme === "dark" || root.dataset.theme === "light"
          ? root.dataset.theme
          : getSystemTheme();
      const nextTheme = currentTheme === "dark" ? "light" : "dark";

      try {
        window.localStorage.setItem(STORAGE_KEY, nextTheme);
      } catch {
        // The visible toggle should still work if storage is unavailable.
      }

      applyTheme(nextTheme);
    });

    mediaQuery.addEventListener("change", () => {
      if (getStoredTheme()) return;
      applyTheme(getSystemTheme());
    });

    document.addEventListener("DOMContentLoaded", () => {
      applyTheme(getStoredTheme() ?? getSystemTheme());
    });

    document.addEventListener("astro:page-load", () => {
      applyTheme(getStoredTheme() ?? getSystemTheme());
    });

    document.addEventListener("astro:after-swap", () => {
      applyTheme(getStoredTheme() ?? getSystemTheme());
    });
  })();
</script>

<script>
  import { bind, play, setEnabled } from "cuelume";

  const SOUND_STORAGE_KEY = "rgo-sound-enabled";
  const root = document.documentElement;

  function getSoundPreference(): boolean {
    try {
      return window.localStorage.getItem(SOUND_STORAGE_KEY) !== "false";
    } catch {
      return true;
    }
  }

  function updateSoundButtons(enabled: boolean): void {
    const label = enabled
      ? "Mute interface sounds"
      : "Enable interface sounds";

    document.querySelectorAll("[data-sound-toggle]").forEach((button) => {
      button.setAttribute("aria-label", label);
      button.setAttribute("aria-pressed", String(enabled));
      button.setAttribute("title", label);

      if (button instanceof HTMLElement) {
        button.dataset.soundState = enabled ? "on" : "off";
      }
    });
  }

  function applySoundPreference(enabled: boolean): void {
    root.dataset.soundEnabled = enabled ? "true" : "false";
    setEnabled(enabled);
    updateSoundButtons(enabled);
  }

  function toggleSound(): void {
    const wasEnabled = root.dataset.soundEnabled !== "false";
    const isEnabled = !wasEnabled;

    // Let the cue finish before muting; when enabling, unmute first.
    if (wasEnabled) play("toggle");
    applySoundPreference(isEnabled);
    if (isEnabled) play("toggle");

    try {
      window.localStorage.setItem(SOUND_STORAGE_KEY, String(isEnabled));
    } catch {
      // The visible control should still work if storage is unavailable.
    }
  }

  bind();
  applySoundPreference(getSoundPreference());

  if (root.dataset.soundControlsInitialized !== "true") {
    root.dataset.soundControlsInitialized = "true";

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest("[data-sound-toggle]")) return;

      toggleSound();
    });

    window.addEventListener("storage", (event) => {
      if (event.key !== SOUND_STORAGE_KEY) return;
      applySoundPreference(event.newValue !== "false");
    });

    document.addEventListener("astro:page-load", () => {
      applySoundPreference(getSoundPreference());
    });

    document.addEventListener("astro:after-swap", () => {
      applySoundPreference(getSoundPreference());
    });
  }
</script>

<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/webp" sizes="32x32" href="/favicon.webp" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<!-- <meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} /> -->

<!-- Umami Analytics -->
<script
  defer
  src="https://analytics.rgo.pt/script.js"
  data-website-id="f8aa3433-d34d-4b3a-9eaa-4b828d2a5338"></script>

<script is:inline>
  (() => {
    const TOKEN_CLASS = "animated-link-token";
    const LINE_CLASS = "animated-link-line";
    const RESIZE_DEBOUNCE_MS = 120;
    let resizeTimeout;
    let mutationObserver;

    function shouldEnhanceLink(anchor) {
      if (!(anchor instanceof HTMLAnchorElement)) return false;
      if (!anchor.href) return false;
      if (anchor.closest("astro-island")) return false;
      if (anchor.closest("nav, button, .socials")) return false;
      if (
        anchor.classList.contains("download-pill") ||
        anchor.classList.contains("button") ||
        anchor.classList.contains("project") ||
        anchor.classList.contains("timeline-entry")
      ) {
        return false;
      }
      if (anchor.querySelector(".card-container, div, p, ul, ol, h1, h2, h3")) {
        return false;
      }
      if (anchor.querySelector("img, svg, video, picture, iframe"))
        return false;

      const originalText =
        anchor.dataset.animatedLinkOriginalText ?? anchor.textContent ?? "";
      const normalizedText = originalText.replace(/\s+/g, " ").trim();

      return normalizedText.length > 0;
    }

    function getOriginalText(anchor) {
      if (anchor.dataset.animatedLinkOriginalText) {
        return anchor.dataset.animatedLinkOriginalText;
      }

      const text = (anchor.textContent ?? "").replace(/\s+/g, " ").trim();
      anchor.dataset.animatedLinkOriginalText = text;
      return text;
    }

    function tokenize(text) {
      return text.match(/\S+\s*/g) ?? [text];
    }

    function appendMeasurementTokens(anchor, tokens) {
      anchor.textContent = "";

      for (const token of tokens) {
        const span = document.createElement("span");
        span.className = TOKEN_CLASS;
        span.textContent = token;
        anchor.appendChild(span);
      }
    }

    function groupTokensIntoLines(anchor) {
      const tokenElements = Array.from(
        anchor.querySelectorAll(`.${TOKEN_CLASS}`),
      );
      const lines = [];
      let currentLine = [];
      let previousTop = null;

      for (const token of tokenElements) {
        const top = Math.round(token.getBoundingClientRect().top);

        if (previousTop === null || Math.abs(top - previousTop) <= 1) {
          currentLine.push(token.textContent ?? "");
        } else {
          lines.push(currentLine.join("").trimEnd());
          currentLine = [token.textContent ?? ""];
        }

        previousTop = top;
      }

      if (currentLine.length > 0) {
        lines.push(currentLine.join("").trimEnd());
      }

      return lines.filter(Boolean);
    }

    function renderAnimatedLines(anchor, lines) {
      anchor.textContent = "";
      anchor.dataset.animatedLink = "true";

      lines.forEach((line, index) => {
        const lineSpan = document.createElement("span");
        lineSpan.className = LINE_CLASS;
        lineSpan.textContent = line;
        anchor.appendChild(lineSpan);

        if (index < lines.length - 1) {
          anchor.appendChild(document.createElement("br"));
        }
      });
    }

    function enhanceAnchor(anchor) {
      if (anchor.closest("astro-island")) return;

      if (!shouldEnhanceLink(anchor)) {
        delete anchor.dataset.animatedLink;
        return;
      }

      const originalText = getOriginalText(anchor);
      const tokens = tokenize(originalText);

      appendMeasurementTokens(anchor, tokens);
      const lines = groupTokensIntoLines(anchor);
      renderAnimatedLines(anchor, lines.length > 0 ? lines : [originalText]);
    }

    function enhanceAnchorsIn(root) {
      if (root instanceof Element && root.closest("astro-island")) return;

      if (root instanceof HTMLAnchorElement) {
        enhanceAnchor(root);
        return;
      }

      if (!(root instanceof Element || root instanceof Document)) return;

      const anchors = root.querySelectorAll("a[href]");
      for (const anchor of anchors) {
        enhanceAnchor(anchor);
      }
    }

    function enhanceAnimatedLinks() {
      enhanceAnchorsIn(document);
    }

    function queueEnhancement() {
      window.clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(
        enhanceAnimatedLinks,
        RESIZE_DEBOUNCE_MS,
      );
    }

    function observeInsertedLinks() {
      mutationObserver?.disconnect();

      if (!document.body) return;

      mutationObserver = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            requestAnimationFrame(() => enhanceAnchorsIn(node));
          }
        }
      });

      mutationObserver.observe(document.body, {
        childList: true,
        subtree: true,
      });
    }

    document.addEventListener("astro:page-load", () => {
      enhanceAnimatedLinks();
      observeInsertedLinks();
    });

    document.addEventListener("astro:after-swap", () => {
      enhanceAnimatedLinks();
      observeInsertedLinks();
    });

    window.addEventListener("resize", queueEnhancement);
  })();
</script>

<!-- View Transitions -->
<ClientRouter />
