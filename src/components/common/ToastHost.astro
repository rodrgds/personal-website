<div id="app-toast" class="app-toast" role="status" aria-live="polite" hidden></div>

<script>
  if (typeof window !== 'undefined') {
    const toastEl = document.getElementById('app-toast');
    let toastVersion = 0;
    let queuedMessage = '';
    let queuedDuration = 1900;

    const showQueuedToast = () => {
      if (!toastEl || !queuedMessage) return;

      const currentVersion = ++toastVersion;

      toastEl.textContent = queuedMessage;
      toastEl.hidden = false;
      toastEl.classList.remove('visible');

      // Split visibility changes across frames so the enter transition can interpolate.
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          if (currentVersion !== toastVersion) return;
          toastEl.classList.add('visible');
        });
      });

      window.setTimeout(() => {
        if (currentVersion !== toastVersion) return;
        toastEl.classList.remove('visible');

        window.setTimeout(() => {
          if (currentVersion !== toastVersion) return;
          toastEl.hidden = true;
        }, 220);
      }, queuedDuration);
    };

    window.addEventListener('app:toast', (event) => {
      if (!(event instanceof CustomEvent)) return;

      const detail = event.detail;
      if (!detail || typeof detail !== 'object') return;

      const maybeMessage = detail.message;
      const maybeDuration = detail.duration;

      if (typeof maybeMessage !== 'string' || !maybeMessage.trim()) return;

      queuedMessage = maybeMessage;
      queuedDuration = typeof maybeDuration === 'number' ? maybeDuration : 1900;
      showQueuedToast();
    });
  }
</script>

<style>
  .app-toast {
    position: fixed;
    left: 50%;
    bottom: 1.1rem;
    transform: translateX(-50%) translateY(0.9rem);
    background: var(--text-color);
    color: var(--background-color);
    padding: 0.5rem 0.78rem;
    border-radius: 0.5rem;
    font-size: 0.88rem;
    font-family: var(--font-family-mono);
    line-height: 1.2;
    opacity: 0;
    transition:
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 80;
    pointer-events: none;
    box-shadow: 0 5px 16px color-mix(in srgb, var(--text-color) 16%, transparent);
  }

  .app-toast.visible {
    opacity: 0.97;
    transform: translateX(-50%) translateY(0);
  }
</style>
