---
export interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  href: string;
  external?: boolean;
}

const { href, class: className, external, ...props } = Astro.props;
const { pathname } = Astro.url;
const isActive = href === pathname || href === pathname.replace(/\/$/, "");

// Set the rel attribute accordingly.
const anchorRel = external ? "me noopener noreferrer" : "me";
const target = external ? "_blank" : undefined;
---

<a
  rel={anchorRel}
  href={href}
  target={target}
  class:list={[className, { active: isActive }]}
  {...props}
>
  <span class="label">
    <slot />
  </span>
  {
    external && (
      <span class="external-mark" aria-hidden="true">
        ↗
      </span>
    )
  }
  {
    isActive && (
      <span
        class="active-line"
        transition:name="active-nav"
        aria-hidden="true"
      />
    )
  }
</a>

<style>
  a {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    padding-bottom: 0.22rem;
    color: var(--link-color);
    font-size: 0.95rem;
    line-height: 1.2;
    text-decoration: none;
    transition:
      opacity 0.2s ease-out,
      transform 0.2s ease-out;
  }

  a:hover,
  a:focus-visible {
    text-decoration: none;
    opacity: 0.8;
    transform: scale(1.1);
  }

  a.active {
    font-weight: 600;
  }

  .label {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .external-mark {
    color: var(--gray-color);
  }

  .active-line {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 2px;
    border-radius: 999px;
    background: var(--link-color);
  }
</style>
