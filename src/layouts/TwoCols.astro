---
import BaseHead from "../components/common/BaseHead.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate?: string;
    updatedDate?: string;
    heroImage?: string;
    katex?: boolean;
  };
}

const {
  content: { title, description, pubDate, updatedDate, heroImage, katex },
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />
    <main>
      <article class="two-col">
        <slot />
      </article>
    </main>
    <Footer />
    <script>
      function groupUsesLayout() {
        const article = document.querySelector(".two-col");
        if (!(article instanceof HTMLElement)) return;
        if (article.dataset.usesGrouped === "true") return;

        const fragment = document.createDocumentFragment();
        let currentCard: HTMLDivElement | null = null;

        for (const node of Array.from(article.childNodes)) {
          if (!(node instanceof HTMLElement)) {
            if (currentCard && node.textContent?.trim()) {
              currentCard.appendChild(node);
            }
            continue;
          }

          if (node.matches("details")) {
            node.classList.add("uses-wide");
            fragment.appendChild(node);
            currentCard = null;
            continue;
          }

          if (node.matches("h2")) {
            node.classList.add("uses-section-title");
            fragment.appendChild(node);
            currentCard = null;
            continue;
          }

          if (node.matches("h3, h4")) {
            currentCard = document.createElement("section");
            currentCard.className = "uses-card";
            currentCard.appendChild(node);
            fragment.appendChild(currentCard);
            continue;
          }

          if (!currentCard) {
            currentCard = document.createElement("section");
            currentCard.className = "uses-card";
            fragment.appendChild(currentCard);
          }

          currentCard.appendChild(node);
        }

        article.replaceChildren(fragment);
        article.dataset.usesGrouped = "true";
      }

      document.addEventListener("astro:page-load", groupUsesLayout);
      document.addEventListener("astro:after-swap", groupUsesLayout);
      groupUsesLayout();
    </script>
  </body>
</html>

<style>
  .two-col :global(img[class*="logo"]) {
    width: 24px !important;
    max-width: 24px;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .two-col :global(.uses-wide),
  .two-col :global(.uses-section-title) {
    grid-column: 1 / -1;
  }

  .two-col :global(.uses-section-title) {
    margin-top: 1.35rem;
  }

  .two-col :global(.uses-card) {
    min-width: 0;
  }

  .two-col :global(.uses-card h3),
  .two-col :global(.uses-card h4) {
    margin-top: 0;
  }

  @media (min-width: 768px) {
    .two-col {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .two-col {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
